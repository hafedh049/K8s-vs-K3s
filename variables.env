# ============================================================
# variables.env — Central Configuration File
# K8s vs K3s Lab Environment · Linux Mint
# ============================================================
# Usage: source variables.env
# ============================================================

# ------------------------------------------------------------
# K8s — Node IPs
# ------------------------------------------------------------
export K8S_CP1_IP="192.168.3.129"       # Control Plane 1 (PRIMARY)
export K8S_CP2_IP="192.168.3.179"       # Control Plane 2 (BACKUP)
export K8S_CP3_IP="192.168.3.181"       # Control Plane 3 (BACKUP)
export K8S_WK1_IP="192.168.3.180"       # Worker Node 1
export K8S_WK2_IP="192.168.3.182"       # Worker Node 2
export K8S_WK3_IP="192.168.3.178"       # Worker Node 3

# ------------------------------------------------------------
# K8s — Node Hostnames
# ------------------------------------------------------------
export K8S_CP1_HOST="cp1"
export K8S_CP2_HOST="cp2"
export K8S_CP3_HOST="cp3"
export K8S_WK1_HOST="wk1"
export K8S_WK2_HOST="wk2"
export K8S_WK3_HOST="wk3"

# ------------------------------------------------------------
# K8s — Keepalived / VIP
# ------------------------------------------------------------
export K8S_VIP="192.168.3.200"          # Virtual IP (Keepalived)
export K8S_VIP_INTERFACE="ens33"        # Network interface on all nodes
export K8S_VIP_ROUTER_ID="51"          # Must be unique on your network
export K8S_VIP_AUTH_PASS="k8s@2026"   # Keepalived auth password

# Keepalived priorities
export K8S_CP1_PRIORITY="100"          # Highest = gets VIP first
export K8S_CP2_PRIORITY="90"
export K8S_CP3_PRIORITY="80"

# ------------------------------------------------------------
# K8s — Cluster Networking
# ------------------------------------------------------------
export K8S_POD_CIDR="10.244.0.0/16"   # Pod network CIDR (Calico)
export K8S_SVC_CIDR="10.96.0.0/12"    # Service network CIDR
export K8S_VERSION="v1.29.0"           # Kubernetes version
export K8S_CALICO_VERSION="v3.27.0"   # Calico CNI version

# ------------------------------------------------------------
# K8s — HAProxy
# ------------------------------------------------------------
export K8S_HAPROXY_PORT="8443"         # HAProxy listen port (6443 used by API)

# ------------------------------------------------------------
# K3s — Single Node
# ------------------------------------------------------------
export K3S_SINGLE_IP="192.168.3.184"   # K3s single server IP
export K3S_SINGLE_HOST="snk"           # K3s single server hostname

# ------------------------------------------------------------
# K3s — Multi-Node
# ------------------------------------------------------------
export K3S_SERVER_IP="192.168.3.184"   # K3s server (control plane)
export K3S_AGENT1_IP="192.168.3.185"   # K3s agent 1
export K3S_AGENT2_IP="192.168.3.186"   # K3s agent 2

export K3S_SERVER_HOST="k3s-server"
export K3S_AGENT1_HOST="k3s-agent-1"
export K3S_AGENT2_HOST="k3s-agent-2"

# ------------------------------------------------------------
# K3s — PostgreSQL (for HA multi-node)
# ------------------------------------------------------------
export K3S_PG_HOST="192.168.3.184"     # PostgreSQL host (can be separate VM)
export K3S_PG_PORT="5432"
export K3S_PG_DB="k3s"
export K3S_PG_USER="k3suser"
export K3S_PG_PASS="k3s@Secure2026"
export K3S_PG_DSN="postgres://${K3S_PG_USER}:${K3S_PG_PASS}@${K3S_PG_HOST}:${K3S_PG_PORT}/${K3S_PG_DB}"

# ------------------------------------------------------------
# K3s — Networking
# ------------------------------------------------------------
export K3S_CLUSTER_CIDR="10.42.0.0/16"
export K3S_SERVICE_CIDR="10.43.0.0/16"
export K3S_CLUSTER_DNS="10.43.0.10"

# ------------------------------------------------------------
# Monitoring
# ------------------------------------------------------------
export GRAFANA_PASSWORD="admin@k8s2026"
export GRAFANA_NODEPORT="32000"
export MONITORING_NAMESPACE="monitoring"

# ------------------------------------------------------------
# Verify loaded
# ------------------------------------------------------------
echo "✅ Variables loaded successfully"
echo "   K8s VIP     : ${K8S_VIP}"
echo "   K8s Masters : ${K8S_CP1_IP}, ${K8S_CP2_IP}, ${K8S_CP3_IP}"
echo "   K8s Workers : ${K8S_WK1_IP}, ${K8S_WK2_IP}, ${K8S_WK3_IP}"
echo "   K3s Server  : ${K3S_SERVER_IP}"
echo "   K3s Agents  : ${K3S_AGENT1_IP}, ${K3S_AGENT2_IP}"
